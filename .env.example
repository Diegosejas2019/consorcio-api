# Servidor
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gestionar_local
# Produccion debe usar la base gestionar_prod.
# QA/Staging debe usar la base gestionar_qa.
# Ejemplos:
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/gestionar_prod
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/gestionar_qa

# Backups MongoDB Atlas
# Usar un usuario de MongoDB de solo lectura para backups.
MONGO_URI=
BACKUP_DIR=backups
BACKUP_STORAGE_PROVIDER=none
KEEP_LOCAL_BACKUP=false

# JWT
JWT_SECRET=tu_clave_secreta_super_segura_aqui_min_32_chars
JWT_EXPIRES_IN=7d

# Cloudinary (comprobantes y backups opcionales)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BACKUP_FOLDER=gestionar/backups

# MercadoPago
# Las credenciales MP (access token, public key, webhook secret) se configuran
# por organizacion desde el panel de admin (PATCH /api/config), no via env vars.
# URL base de la API: se usa para construir la notification_url del webhook de MP.
APP_BASE_URL=https://tu-dominio.railway.app

# Email
BREVO_API_KEY=
EMAIL_FROM="ConsorcioPro <noreply@tu-dominio.com>"
SUPPORT_EMAIL=soporte@tu-dominio.com

# Firebase Admin (Push Notifications)
# Descargar el archivo serviceAccountKey.json desde Firebase Console.
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada\n-----END PRIVATE KEY-----\n"

# CORS
# Origenes permitidos separados por coma.
# Obligatorio en production/qa/staging.
ALLOWED_ORIGINS=http://localhost:5500,https://tu-dominio.com

# Sentry
SENTRY_DSN=

# API interna
# Clave para POST /api/internal/create-organization.
# Generar con: openssl rand -hex 32
INTERNAL_API_KEY=
