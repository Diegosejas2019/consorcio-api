# ── Servidor ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/consorcio
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/consorcio

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=tu_clave_secreta_super_segura_aqui_min_32_chars
JWT_EXPIRES_IN=7d

# ── Cloudinary (almacenamiento de comprobantes) ───────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── MercadoPago ───────────────────────────────────────
# Las credenciales MP (access token, public key, webhook secret) se configuran
# por organización desde el panel de admin (PATCH /api/config), no via env vars.
# URL base de la API — se usa para construir la notification_url del webhook de MP
APP_BASE_URL=https://tu-dominio.railway.app

# ── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM="ConsorcioPro <noreply@tu-dominio.com>"

# ── Firebase Admin (Push Notifications) ──────────────
# Descargá el archivo serviceAccountKey.json desde Firebase Console
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada\n-----END PRIVATE KEY-----\n"

# ── CORS ──────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5500,https://tu-dominio.com

# ── Sentry (Error Tracking) ───────────────────────────
# DSN del proyecto Node.js en sentry.io
SENTRY_DSN=
